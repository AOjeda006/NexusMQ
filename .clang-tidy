# Análisis estático (Core Guidelines, bugprone, performance, modernize) y
# enforcement del naming del proyecto vía readability-identifier-naming.
# Algunos chequeos ruidosos o de criterio se desactivan explícitamente.
#
# Desactivados por chocar con el núcleo de corrutinas (decisión de proyecto):
#  - readability-convert-member-functions-to-static: los puntos de personalización
#    (await_ready/initial_suspend/final_suspend…) los invoca el lenguaje sobre una
#    instancia, así que se mantienen no estáticos; este check los querría estáticos,
#    lo que a su vez dispara readability-static-accessed-through-instance en cada
#    rampa de corrutina (conflicto irresoluble). Conservamos el segundo (más útil).
#  - cppcoreguidelines-avoid-reference-coroutine-parameters: en el modelo
#    thread-per-core las corrutinas reciben referencias a objetos REACTOR-LOCAL
#    (Proactor, Socket, Buffer) que las sobreviven por construcción; Proactor es
#    abstracto y no puede pasarse por valor. La referencia es correcta y segura.
#
# Desactivado por chocar con una convención de proyecto (check nuevo de clang-tidy 21):
#  - readability-use-concise-preprocessor-directives: el proyecto usa de forma
#    uniforme `#if defined(X)` / `#if !defined(X)` para las guardas de plataforma
#    (más algunas compuestas `#if defined(A) && defined(B)` que este check ni
#    siquiera puede simplificar). Reescribir a `#ifdef`/`#ifndef` rompería esa
#    consistencia sin ganancia real; se conserva la convención (ver CLAUDE.md).
---
Checks: >
  -*,
  bugprone-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*,
  misc-*,
  -modernize-use-trailing-return-type,
  -bugprone-easily-swappable-parameters,
  -readability-identifier-length,
  -misc-include-cleaner,
  -misc-non-private-member-variables-in-classes,
  -cppcoreguidelines-non-private-member-variables-in-classes,
  -cppcoreguidelines-avoid-magic-numbers,
  -readability-magic-numbers,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-bounds-constant-array-index,
  -cppcoreguidelines-pro-bounds-avoid-unchecked-container-access,
  -cppcoreguidelines-pro-type-vararg,
  -cppcoreguidelines-pro-type-union-access,
  -cppcoreguidelines-avoid-reference-coroutine-parameters,
  -readability-convert-member-functions-to-static,
  -readability-use-concise-preprocessor-directives,
  -portability-avoid-pragma-once

WarningsAsErrors: '*'
HeaderFilterRegex: '.*/(src|tools|client)/.*\.hpp$'
FormatStyle: file

CheckOptions:
  # Naming del proyecto (convenciones C++): tipos PascalCase; funciones/variables/
  # miembros snake_case; constantes kPascalCase; miembros privados con sufijo _;
  # namespaces en minúscula. Sin prefijo I en interfaces.
  readability-identifier-naming.NamespaceCase: lower_case
  readability-identifier-naming.ClassCase: CamelCase
  readability-identifier-naming.StructCase: CamelCase
  readability-identifier-naming.UnionCase: CamelCase
  readability-identifier-naming.EnumCase: CamelCase
  readability-identifier-naming.EnumConstantCase: CamelCase
  readability-identifier-naming.TypeAliasCase: CamelCase
  readability-identifier-naming.TypedefCase: CamelCase
  readability-identifier-naming.FunctionCase: lower_case
  readability-identifier-naming.MethodCase: lower_case
  readability-identifier-naming.VariableCase: lower_case
  readability-identifier-naming.ParameterCase: lower_case
  readability-identifier-naming.MemberCase: lower_case
  readability-identifier-naming.PrivateMemberSuffix: _
  readability-identifier-naming.ProtectedMemberSuffix: _
  readability-identifier-naming.ConstexprVariableCase: CamelCase
  readability-identifier-naming.ConstexprVariablePrefix: k
  readability-identifier-naming.GlobalConstantCase: CamelCase
  readability-identifier-naming.GlobalConstantPrefix: k
  readability-identifier-naming.MacroDefinitionCase: UPPER_CASE
