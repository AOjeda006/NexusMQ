# Build out-of-source (presets escriben en build/<preset>/)
/build/
/out/
cmake-build-*/

# Artefactos de vcpkg en modo manifest
/vcpkg_installed/

# Caché de herramientas / editores
compile_commands.json
.cache/
.vs/
*.user

# VS Code: versiona solo la config compartida del proyecto; ignora lo personal.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# Datos de ejecución del broker (logs de partición, etc.)
/data/

# Python (bindings)
__pycache__/
*.pyc
