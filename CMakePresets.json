{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "linux-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "linux-gcc",
      "inherits": "linux-base",
      "displayName": "Linux GCC (C++23, Debug)",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-clang",
      "inherits": "linux-base",
      "displayName": "Linux Clang + libc++ (C++23, Debug)",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Debug",
        "_comment_libcxx": "Clang necesita libc++ para std::expected (libstdc++ lo bloquea por __cpp_concepts). Global, para que también las deps de FetchContent usen libc++ (mismo ABI). Se usa clang también como compilador C porque -stdlib=libc++ llega al enlace de C.",
        "CMAKE_CXX_FLAGS": "-stdlib=libc++",
        "CMAKE_EXE_LINKER_FLAGS": "-stdlib=libc++"
      }
    },
    {
      "name": "linux-gcc-release",
      "inherits": "linux-gcc",
      "displayName": "Linux GCC (C++23, Release — para benchmarks)",
      "cacheVariables": {
        "_comment_release": "Build optimizada (-O3, NDEBUG) para las campañas de latencia (Bloque L). Las cifras de rendimiento solo son representativas con optimización; los presets Debug son para desarrollo y tests.",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-gcc-asan",
      "inherits": "linux-gcc",
      "displayName": "Linux GCC + sanitizers (ASan/UBSan)",
      "cacheVariables": {
        "NEXUS_SANITIZERS": "ON"
      }
    },
    {
      "name": "linux-gcc-tsan",
      "inherits": "linux-gcc",
      "displayName": "Linux GCC + ThreadSanitizer (colas lock-free)",
      "cacheVariables": {
        "NEXUS_TSAN": "ON"
      }
    },
    {
      "name": "windows-msvc",
      "displayName": "Windows MSVC (IOCP) [nexus-io portado, F10 — ver ADR-0022]",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "cacheVariables": {
        "_comment_scaffold": "Build Windows. La capa de E/S (nexus-io: File/Socket→Win32 + IocpBackend) está portada y compile-verificada con MinGW (ADR-0022); CMake compila iocp_backend.cpp y enlaza ws2_32/mswsock en WIN32. El resto del árbol (reactor pinning, nexusd con señales POSIX) sigue Linux-nativo: un nexusd Windows completo es trabajo futuro. Para compile-verificar solo nexus-io sin MSVC: tools/verify-windows-io.sh. Oculto fuera de Windows por 'condition'.",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    { "name": "linux-gcc", "configurePreset": "linux-gcc" },
    { "name": "linux-gcc-release", "configurePreset": "linux-gcc-release" },
    { "name": "linux-clang", "configurePreset": "linux-clang" },
    { "name": "linux-gcc-asan", "configurePreset": "linux-gcc-asan" },
    { "name": "linux-gcc-tsan", "configurePreset": "linux-gcc-tsan" }
  ],
  "testPresets": [
    { "name": "linux-gcc", "configurePreset": "linux-gcc", "output": { "outputOnFailure": true } },
    { "name": "linux-clang", "configurePreset": "linux-clang", "output": { "outputOnFailure": true } },
    { "name": "linux-gcc-asan", "configurePreset": "linux-gcc-asan", "output": { "outputOnFailure": true } },
    { "name": "linux-gcc-tsan", "configurePreset": "linux-gcc-tsan", "output": { "outputOnFailure": true } }
  ]
}
