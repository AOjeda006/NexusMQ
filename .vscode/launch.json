{
  "version": "0.2.0",
  "configurations": [
    {
      // Depura el "launch target" seleccionado en CMake Tools (barra inferior):
      // nexus-tests o nexus-bench. Requiere gdb en WSL (sudo apt install -y gdb).
      "name": "Depurar target CMake (gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Habilitar pretty-printing en gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
